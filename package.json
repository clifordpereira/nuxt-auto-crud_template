{
  "name": "auto-crud.clifland.in",
  "private": true,
  "type": "module",
  "scripts": {
    "// --- Development ---": "",
    "dev": "nuxi dev",
    "postinstall": "nuxi prepare",
    "preview": "nuxi preview",
    "lint": "eslint .",
    "typecheck": "nuxi typecheck",
    "// --- Database (NuxtHub/Drizzle) ---": "",
    "db:generate": "nuxi db generate",
    "db:migrate": "nuxi db migrate",
    "db:studio": "nuxi db studio",
    "// --- Build ---": "",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxi build",
    "// --- Prod ---": "",
    "migrate:prod": "nuxi db migrate --remote",
    "deploy:prod": "bun run build && bun run migrate:prod && wrangler deploy",
    "logs:prod": "wrangler tail",
    "// --- Staging ---": "",
    "migrate:staging": "nuxi db migrate --remote --env staging",
    "deploy:staging": "bun run build && bun run migrate:staging && wrangler deploy --env staging",
    "logs:staging": "wrangler tail --env staging",
    "// --- Testing ---": "",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.92",
    "@iconify-json/simple-icons": "^1.2.71",
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.4.0",
    "@nuxthub/core": "^0.10.6",
    "@standard-schema/spec": "^1.1.0",
    "@vueuse/nuxt": "^14.2.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^1.0.0-beta.9-e89174b",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-auto-crud": "^2.1.4",
    "nuxt-delay-hydration": "^1.3.8",
    "nuxt-security": "^2.5.1",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/vscode-icons": "^1.2.43",
    "@libsql/client": "^0.17.0",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/test-utils": "^3.23.0",
    "@types/bcryptjs": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "eslint": "^9.39.2",
    "happy-dom": "^20.6.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "playwright-core": "^1.58.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4",
    "wrangler": "^4.67.0",
    "xlsx": "^0.18.5"
  },
  "packageManager": "bun@1.2.5"
}
